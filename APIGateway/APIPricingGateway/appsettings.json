{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {

      // Demo 1: Round-Robin Load Balancing + Rate Limiting + Header Transforms
      // Hit /getprice multiple times to watch it alternate between Pessimistic and Optimistic.
      // After 5 requests in 10 seconds the gateway returns 429 Too Many Requests.
      // Check response headers for X-Served-By and X-Gateway.
      "pricing-roundrobin-route": {
        "ClusterId": "pricing-roundrobin-cluster",
        "RateLimiterPolicy": "pricing-rate-limit",
        "Match": {
          "Path": "/getprice"
        },
        "Transforms": [
          { "RequestHeader": "X-Gateway", "Set": "APIPricingGateway" },
          { "ResponseHeader": "X-Served-By", "Append": "YARP-Gateway", "When": "Always" }
        ]
      },

      // Demo 2: Path-Based API Versioning
      // /v1/getprice → always Pessimistic (YARP strips the /v1 prefix before forwarding)
      // /v2/getprice → always Optimistic (YARP strips the /v2 prefix before forwarding)
      "pricing-v1-route": {
        "ClusterId": "pessimistic-cluster",
        "Match": {
          "Path": "/v1/getprice"
        },
        "Transforms": [
          { "PathRemovePrefix": "/v1" },
          { "ResponseHeader": "X-Api-Version", "Append": "v1", "When": "Always" }
        ]
      },
      "pricing-v2-route": {
        "ClusterId": "optimistic-cluster",
        "Match": {
          "Path": "/v2/getprice"
        },
        "Transforms": [
          { "PathRemovePrefix": "/v2" },
          { "ResponseHeader": "X-Api-Version", "Append": "v2", "When": "Always" }
        ]
      },

      // Demo 3: Random Load Balancing
      // PathSet rewrites the path to /home before forwarding — the fix for
      // PathRemovePrefix leaving a trailing slash against a destination that already
      // encodes a sub-path.
      "random-route": {
        "ClusterId": "random-cluster",
        "Match": {
          "Path": "/random"
        },
        "Transforms": [
          {
            "PathSet": "/home"
          }
        ]
      },

      // Catch-all: forwards everything else to the Pessimistic service.
      "catch-all-route": {
        "ClusterId": "pessimistic-cluster",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },

    "Clusters": {

      // Round-Robin across both services. Passive health checks mark a destination
      // unhealthy after consecutive failures and stop sending traffic to it.
      "pricing-roundrobin-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Passive": {
            "Enabled": true
          }
        },
        "Destinations": {
          "pessimistic": {
            "Address": "https+http://PessimisticPricingService"
          },
          "optimistic": {
            "Address": "https+http://OptimisticPricingService"
          }
        }
      },
      "pessimistic-cluster": {
        "HealthCheck": {
          "Passive": {
            "Enabled": true
          }
        },
        "Destinations": {
          "pessimistic": {
            "Address": "https+http://PessimisticPricingService"
          }
        }
      },

      "optimistic-cluster": {
        "HealthCheck": {
          "Passive": {
            "Enabled": true
          }
        },
        "Destinations": {
          "optimistic": {
            "Address": "https+http://OptimisticPricingService"
          }
        }
      },

      // Random policy — each request independently picks a random destination.
      "random-cluster": {
        "LoadBalancingPolicy": "Random",
        "HealthCheck": {
          "Passive": {
            "Enabled": true
          }
        },
        "Destinations": {
          "pessimistic": {
            "Address": "https+http://PessimisticPricingService"
          },
          "optimistic": {
            "Address": "https+http://OptimisticPricingService"
          }
        }
      }
    }
  }
}
